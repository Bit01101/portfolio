---
import Grid from "./Part/Grid.astro";
---

<div id="header-container">
  <div id="my-name-context-cut">
    <div id="right-name" class="part-name">
      <p>Kuvaev</p>
    </div>
    <div id="left-name" class="part-name">
      <p>Egor</p>
    </div>
  </div>
  <Grid id="grid-for-name" class="grid-position-left-top" />
</div>

<style>
  #header-container {
    width: 100%;
    height: 100%;
  }

  #my-name-context-cut {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 10%;
    position: relative;
    --offset-part-text: 20%;
  }

  .part-name p {
    font-size: calc(6rem * var(--aspecto-ratio));
  }

  #right-name {
    display: flex;
    align-items: flex-end;
    padding-right: var(--offset-part-text);
  }

  #left-name {
    display: flex;
    align-items: flex-end;
    padding-left: var(--offset-part-text);
  }

  .positioned-grid {
    position: absolute;
    top: 0;
    left: 0;
  }
</style>
